<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quiz Callejero Valencia — Parque Norte</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,sans-serif;background:#f5f5f5;color:#1a1a1a}
#header{background:#1565C0;color:#fff;padding:12px 16px;display:flex;align-items:center;justify-content:space-between}
#header h1{font-size:16px;font-weight:500}
#stats{display:flex;gap:12px;font-size:13px}
#stats span b{font-weight:600}
#map{width:100%;height:calc(100vh - 160px)}
#panel{position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1px solid #ddd;padding:12px 16px;z-index:1000}
#calle-info{font-size:13px;color:#555;margin-bottom:8px;text-align:center}
#calle-info b{color:#1a1a1a;font-size:15px}
#opciones{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px}
.opcion{background:#f0f4ff;border:1px solid #c5d3f0;border-radius:8px;padding:10px 12px;font-size:13px;cursor:pointer;text-align:left;transition:all .15s;line-height:1.3}
.opcion:hover{background:#dce8ff;border-color:#7da7e8}
.opcion.correcto{background:#e8f5e9;border-color:#43a047;color:#1b5e20;font-weight:500}
.opcion.incorrecto{background:#ffebee;border-color:#e53935;color:#b71c1c}
.opcion.mostrar{background:#e8f5e9;border-color:#43a047;color:#1b5e20}
.opcion:disabled{cursor:default}
#feedback{text-align:center;font-size:13px;font-weight:500;min-height:20px;margin-bottom:6px}
#feedback.ok{color:#2e7d32}
#feedback.ko{color:#c62828}
#btn-sig{width:100%;background:#1565C0;color:#fff;border:none;border-radius:8px;padding:10px;font-size:14px;font-weight:500;cursor:pointer;display:none}
#btn-sig:hover{background:#0d47a1}
#loading{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:#fff;border-radius:12px;padding:24px 32px;box-shadow:0 4px 20px rgba(0,0,0,.15);text-align:center;z-index:2000;font-size:14px;color:#555}
#loading.hide{display:none}
#tipo-badge{display:inline-block;font-size:11px;padding:2px 8px;border-radius:4px;margin-right:6px;font-weight:500}
.del{background:#E3F2FD;color:#0D47A1}
.lon{background:#E8F5E9;color:#1B5E20}
.tra{background:#FFF3E0;color:#E65100}
#filtros{display:flex;gap:6px;padding:8px 16px;background:#fff;border-bottom:1px solid #eee;flex-wrap:wrap}
.f-btn{background:#f0f4ff;border:1px solid #c5d3f0;border-radius:6px;padding:4px 10px;font-size:12px;cursor:pointer;transition:all .15s}
.f-btn.active{background:#1565C0;color:#fff;border-color:#1565C0}
</style>
</head>
<body>

<div id="header">
  <h1>Quiz Callejero — Parque Norte</h1>
  <div id="stats">
    <span>✓ <b id="s-ok">0</b></span>
    <span>✗ <b id="s-fail">0</b></span>
    <span><b id="s-pct">—</b></span>
  </div>
</div>

<div id="filtros">
  <span style="font-size:12px;color:#666;line-height:26px">Tipo:</span>
  <button class="f-btn active" onclick="setTipo('all',this)">Todas</button>
  <button class="f-btn" onclick="setTipo('del',this)">Delimitación</button>
  <button class="f-btn" onclick="setTipo('lon',this)">Longitudinal</button>
  <button class="f-btn" onclick="setTipo('tra',this)">Transversal</button>
</div>

<div id="map"></div>

<div id="panel">
  <div id="calle-info">Cargando...</div>
  <div id="opciones"></div>
  <div id="feedback"></div>
  <button id="btn-sig" onclick="siguiente()">Siguiente →</button>
</div>

<div id="loading">
  <div style="font-size:24px;margin-bottom:8px">🗺️</div>
  <div id="loading-text">Cargando mapa...</div>
</div>

<script>
const CALLES = [
  {n:"Av del Puerto", t:"del"},
  {n:"Pza Zaragoza", t:"del"},
  {n:"Paseo Alameda", t:"del"},
  {n:"Pza América", t:"del"},
  {n:"Av Navarro Reverter", t:"del"},
  {n:"C Don Juan de Austria", t:"del"},
  {n:"C Barcas", t:"del"},
  {n:"C Moratín", t:"del"},
  {n:"C San Vicente", t:"del"},
  {n:"C Caballeros", t:"del"},
  {n:"Av Guadalaviar", t:"del"},
  {n:"C Llano de Zaidía", t:"del"},
  {n:"Av Constitución", t:"del"},
  {n:"Av Dr Peset Aleixandre", t:"del"},
  {n:"Av Blasco Ibañez", t:"lon"},
  {n:"C Serpis", t:"lon"},
  {n:"C Gorgos", t:"lon"},
  {n:"Av Tarongers", t:"lon"},
  {n:"C Rio Tajo", t:"lon"},
  {n:"C Riu Bidasoa", t:"lon"},
  {n:"Av Primado Reig", t:"lon"},
  {n:"C Campoamor", t:"lon"},
  {n:"C Mendizabal", t:"lon"},
  {n:"C Ramiro de Maeztu", t:"lon"},
  {n:"C Eolo", t:"lon"},
  {n:"C Caravaca", t:"lon"},
  {n:"C Paz", t:"lon"},
  {n:"C Mar", t:"lon"},
  {n:"C Nau", t:"lon"},
  {n:"Av Valladolid", t:"lon"},
  {n:"C Finlandia", t:"lon"},
  {n:"C Monforte", t:"lon"},
  {n:"Av Suecia", t:"tra"},
  {n:"Av Aragón", t:"tra"},
  {n:"Av Cataluña", t:"tra"},
  {n:"Av Cardenal Benlloch", t:"tra"},
  {n:"C Doctor Fleming", t:"tra"},
  {n:"C Sagunto", t:"tra"},
  {n:"C Bilbao", t:"tra"},
  {n:"C Chile", t:"tra"},
  {n:"C Industria", t:"tra"},
  {n:"C Clariano", t:"tra"},
  {n:"C Vinaroz", t:"tra"},
  {n:"C Alboraya", t:"tra"},
  {n:"Av Constitucion", t:"tra"},
];

const OSM_NAMES = {
  "Av del Puerto": "Avinguda del Port",
  "Pza Zaragoza": "Plaça de Saragossa",
  "Paseo Alameda": "Passeig de l'Albereda",
  "Pza América": "Plaça d'Amèrica",
  "Av Navarro Reverter": "Avinguda de Navarro Reverter",
  "C Don Juan de Austria": "Carrer de Joan d'Àustria",
  "C Barcas": "Carrer de les Barques",
  "C Moratín": "Carrer de Moratín",
  "C San Vicente": "Carrer de Sant Vicent Màrtir",
  "C Caballeros": "Carrer dels Cavallers",
  "Av Guadalaviar": "Carrer de Guillem de Castro",
  "C Llano de Zaidía": "Carrer del Pla de la Saïdia",
  "Av Constitución": "Avinguda de la Constitució",
  "Av Dr Peset Aleixandre": "Avinguda del Doctor Peset Aleixandre",
  "Av Blasco Ibañez": "Avinguda de Blasco Ibáñez",
  "C Serpis": "Carrer del Serpis",
  "C Gorgos": "Carrer del Gorgos",
  "Av Tarongers": "Avinguda dels Tarongers",
  "C Rio Tajo": "Carrer del Riu Tajo",
  "C Riu Bidasoa": "Carrer del Riu Bidasoa",
  "Av Primado Reig": "Avinguda del Primat Reig",
  "C Campoamor": "Carrer de Campoamor",
  "C Mendizabal": "Carrer de Mendizábal",
  "C Ramiro de Maeztu": "Carrer de Ramiro de Maeztu",
  "C Eolo": "Carrer d'Eolo",
  "C Caravaca": "Carrer de Caravaca",
  "C Paz": "Carrer de la Pau",
  "C Mar": "Carrer del Mar",
  "C Nau": "Carrer de la Nau",
  "Av Valladolid": "Avinguda de Valladolid",
  "C Finlandia": "Carrer de Finlàndia",
  "C Monforte": "Carrer de Montfort",
  "Av Suecia": "Avinguda de Suècia",
  "Av Aragón": "Avinguda d'Aragó",
  "Av Cataluña": "Avinguda de Catalunya",
  "Av Cardenal Benlloch": "Avinguda del Cardenal Benlloch",
  "C Doctor Fleming": "Carrer del Doctor Fleming",
  "C Sagunto": "Carrer de Sagunt",
  "C Bilbao": "Carrer de Bilbao",
  "C Chile": "Carrer de Xile",
  "C Industria": "Carrer de la Indústria",
  "C Clariano": "Carrer del Clariano",
  "C Vinaroz": "Carrer de Vinaròs",
  "C Alboraya": "Carrer d'Alboraia",
  "Av Constitucion": "Avinguda de la Constitució",
};

const map = L.map('map').setView([39.478, -0.376], 14);
L.tileLayer('https://{s}.basemaps.cartocdn.com/light_nolabels/{z}/{x}/{y}{r}.png',{
  attribution:'&copy; OpenStreetMap &copy; CARTO', maxZoom:19
}).addTo(map);

let currentLayer = null;
let cola = [], idx = 0, ok = 0, fail = 0, respondido = false;
let actual = null;
let filtroTipo = 'all';
let cache = {};

function setTipo(t, btn){
  filtroTipo = t;
  document.querySelectorAll('.f-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  buildCola();
  siguiente();
}

function buildCola(){
  cola = CALLES.filter(c => filtroTipo==='all' || c.t===filtroTipo);
  cola = [...cola].sort(()=>Math.random()-.5);
  idx = 0;
}

async function getGeometry(nombre){
  if(cache[nombre]) return cache[nombre];
  const osmName = OSM_NAMES[nombre] || nombre;
  const query = `[out:json][timeout:15];area["name"="València"]["admin_level"="8"]->.city;way["name"="${osmName}"](area.city);out geom;`;
  const url = `https://overpass-api.de/api/interpreter?data=${encodeURIComponent(query)}`;
  try {
    const r = await fetch(url);
    const d = await r.json();
    if(d.elements && d.elements.length > 0){
      const coords = [];
      for(const el of d.elements){
        if(el.geometry) coords.push(...el.geometry.map(p=>[p.lat,p.lon]));
      }
      cache[nombre] = coords;
      return coords;
    }
  } catch(e){}
  return null;
}

function getOpciones(correcta){
  const pool = CALLES.filter(c => c.n !== correcta.n && (filtroTipo==='all' || c.t===filtroTipo));
  const shuffled = pool.sort(()=>Math.random()-.5).slice(0,3);
  const opts = [...shuffled, correcta].sort(()=>Math.random()-.5);
  return opts;
}

function mostrarLoading(txt){
  document.getElementById('loading').classList.remove('hide');
  document.getElementById('loading-text').textContent = txt;
}
function ocultarLoading(){
  document.getElementById('loading').classList.add('hide');
}

async function siguiente(){
  respondido = false;
  document.getElementById('feedback').textContent = '';
  document.getElementById('feedback').className = '';
  document.getElementById('btn-sig').style.display = 'none';
  if(currentLayer){ map.removeLayer(currentLayer); currentLayer=null; }

  if(idx >= cola.length) buildCola();
  if(!cola.length){ document.getElementById('calle-info').innerHTML='Sin calles con ese filtro'; return; }

  actual = cola[idx++];
  mostrarLoading(`Buscando ${actual.n}...`);

  const coords = await getGeometry(actual.n);
  ocultarLoading();

  const tl = actual.t==='del'?'Delimitación':actual.t==='lon'?'Longitudinal':'Transversal';
  const tc = actual.t==='del'?'del':actual.t==='lon'?'lon':'tra';
  document.getElementById('calle-info').innerHTML = `<span id="tipo-badge" class="${tc}">${tl}</span><b>¿Qué calle es esta?</b>`;

  if(coords && coords.length > 0){
    currentLayer = L.polyline(coords, {color:'#1565C0', weight:6, opacity:0.9}).addTo(map);
    map.fitBounds(currentLayer.getBounds(), {padding:[40,40], maxZoom:17});
  } else {
    document.getElementById('calle-info').innerHTML += ' <span style="color:#e53935;font-size:12px">(no encontrada en OSM)</span>';
  }

  const opciones = getOpciones(actual);
  const div = document.getElementById('opciones');
  div.innerHTML = '';
  for(const op of opciones){
    const btn = document.createElement('button');
    btn.className = 'opcion';
    btn.textContent = op.n;
    btn.onclick = () => responder(op.n, btn, opciones);
    div.appendChild(btn);
  }
}

function responder(nombre, btnClicado, opciones){
  if(respondido) return;
  respondido = true;
  const correcto = nombre === actual.n;
  if(correcto){ ok++; btnClicado.className='opcion correcto'; }
  else{
    fail++;
    btnClicado.className='opcion incorrecto';
    document.querySelectorAll('.opcion').forEach(b=>{
      if(b.textContent===actual.n) b.className='opcion mostrar';
    });
  }
  document.querySelectorAll('.opcion').forEach(b=>b.disabled=true);
  const fb = document.getElementById('feedback');
  fb.textContent = correcto ? '✓ Correcto' : '✗ Era: '+actual.n;
  fb.className = correcto ? 'ok' : 'ko';
  const t = ok+fail;
  document.getElementById('s-ok').textContent=ok;
  document.getElementById('s-fail').textContent=fail;
  document.getElementById('s-pct').textContent=Math.round(ok/t*100)+'%';
  document.getElementById('btn-sig').style.display='block';

  if(currentLayer) currentLayer.setStyle({color: correcto?'#2e7d32':'#c62828'});
}

buildCola();
siguiente();
</script>
</body>
</html>
